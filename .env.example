NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: point static media at a CDN/R2 bucket instead of local /public assets.
NEXT_PUBLIC_ASSETS_BASE_URL=
NEXT_PUBLIC_ROCK_BENCH_R2_URL=

# Optional: enables subscribe and voting API routes.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: enables /lab/depth-clock-v3 upload-to-depth generation via Comfy Cloud.
# COMFY_API_KEY is also accepted for compatibility with the Comfy CLI.
COMFY_CLOUD_API_KEY=
COMFY_CLOUD_BASE_URL=https://cloud.comfy.org
